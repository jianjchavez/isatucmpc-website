# Cloudflare Pages security headers — applied to every route.
# Format docs: https://developers.cloudflare.com/pages/configuration/headers/
#
# CSP notes (why each source is allowed):
#   script  'unsafe-inline'        → Astro emits small inline scripts + Turnstile onload callback
#           challenges.cloudflare  → Turnstile api.js
#           cloudflareinsights     → CF Web Analytics beacon
#   style   'unsafe-inline'        → Leaflet + Astro inline styles
#           unpkg.com              → leaflet.css
#   img     *.tile.openstreetmap   → map tiles;  unpkg → Leaflet marker icons;  data: → inlined assets
#   connect workers.dev            → contact/membership form POSTs;  Turnstile + CF beacon callbacks
#   frame   challenges.cloudflare  → Turnstile widget iframe
# If you add a new third-party (font CDN, video embed, analytics), extend the matching directive.

/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://challenges.cloudflare.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://unpkg.com; img-src 'self' data: https://*.tile.openstreetmap.org https://unpkg.com; font-src 'self' data:; connect-src 'self' https://isatucmpc-forms.jianjchavez.workers.dev https://challenges.cloudflare.com https://cloudflareinsights.com https://static.cloudflareinsights.com; frame-src https://challenges.cloudflare.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://isatucmpc-forms.jianjchavez.workers.dev; object-src 'none'; upgrade-insecure-requests
  Strict-Transport-Security: max-age=31536000
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()
  Cross-Origin-Opener-Policy: same-origin
