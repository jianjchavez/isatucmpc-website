---
import PageLayout from '~/layouts/PageLayout.astro';
import Button from '~/components/Button.astro';
---
<PageLayout title="Not Found" description="The page you're looking for doesn't exist." noIndex>
  <section class="container-page py-32 text-center">
    <div class="font-display font-extrabold text-orange text-7xl mb-4">404</div>
    <h1 class="text-3xl mb-3">Page not found</h1>
    <p class="text-slate mb-8">The page you're looking for doesn't exist or has moved.</p>
    <Button href="/" variant="primary" showArrow>Back to home</Button>
  </section>
</PageLayout>
