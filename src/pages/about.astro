---
import PageLayout from '~/layouts/PageLayout.astro';
import Eyebrow from '~/components/Eyebrow.astro';
import Button from '~/components/Button.astro';
import GradientOrb from '~/components/GradientOrb.astro';
import Timeline from '~/components/Timeline.astro';
import HistoryNarrative from '~/components/HistoryNarrative.astro';
import BodCard from '~/components/BodCard.astro';
import CoopMarque from '~/components/CoopMarque.astro';
import { BOARD } from '~/data/board';
import { PRINCIPLES } from '~/data/principles';
import { GOALS } from '~/data/goals';
import * as Lucide from 'lucide-astro';

const toPascal = (s: string) => s.split('-').map(p => p[0].toUpperCase() + p.slice(1)).join('');
const iconOf = (name: string) => (Lucide as Record<string, any>)[toPascal(name)] ?? Lucide.Circle;
const VisionIcon = Lucide.Telescope;
const MissionIcon = Lucide.Target;
---
<PageLayout title="About" description="Serving our community since 1964 — our history, our cooperative goals, and the governance that keeps us accountable to our members.">
  <!-- HERO -->
  <section class="relative bg-navy text-white overflow-hidden">
    <GradientOrb position="top-right" size="md" intensity={0.2} />
    <div class="container-page py-16 md:py-24 relative">
      <Eyebrow color="orange">Our story</Eyebrow>
      <h1 class="mt-4 text-4xl md:text-5xl text-white max-w-3xl">Serving our community since 1964.</h1>
      <p class="mt-4 text-lg md:text-xl text-white/85 max-w-2xl font-light">Born from the spirit of cooperation among the ISAT U community, ISATUCMPC has grown into a registered multi-purpose cooperative serving members across credit, savings, and on-campus services — guided always by the principle of service over and above profit.</p>
    </div>
  </section>

  <!-- TIMELINE -->
  <section class="container-page py-20">
    <Eyebrow>Our journey</Eyebrow>
    <h2 class="mt-3 text-3xl md:text-4xl">Six decades of cooperation</h2>
    <div class="mt-12">
      <Timeline />
    </div>
  </section>

  <!-- HISTORY -->
  <section class="bg-brand-bg">
    <HistoryNarrative />
  </section>

  <!-- VISION & MISSION -->
  <section class="container-page py-20">
    <Eyebrow>What drives us</Eyebrow>
    <h2 class="mt-3 text-3xl md:text-4xl max-w-2xl">Our vision and mission.</h2>
    <div class="mt-10 grid md:grid-cols-2 gap-6">
      <div class="bg-white border-t-[3px] border-orange rounded-b-lg p-7 shadow-sm">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-11 h-11 rounded-lg bg-orange/10 text-orange flex items-center justify-center"><VisionIcon class="w-6 h-6" /></div>
          <div class="text-xs font-display font-bold text-orange uppercase tracking-wider">Vision</div>
        </div>
        <p class="text-lg text-ink leading-relaxed">ISATUCMPC is an effective catalyst for enhancing the quality of life of its members through economic development and social justice.</p>
      </div>
      <div class="bg-white border-t-[3px] border-navy rounded-b-lg p-7 shadow-sm">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-11 h-11 rounded-lg bg-navy/5 text-navy flex items-center justify-center"><MissionIcon class="w-6 h-6" /></div>
          <div class="text-xs font-display font-bold text-navy uppercase tracking-wider">Mission</div>
        </div>
        <p class="text-lg text-ink leading-relaxed">The cooperative shall serve to meet the economic and social needs of its members through entrepreneurial endeavors and financial assistance based on self-help and resource pooling — maximizing benefits and synergizing the entire membership.</p>
      </div>
    </div>
  </section>

  <!-- GOALS -->
  <section class="bg-brand-bg">
    <div class="container-page py-20">
      <Eyebrow>Goals & purpose</Eyebrow>
      <h2 class="mt-3 text-3xl md:text-4xl max-w-2xl">To help improve the quality of life of our members.</h2>
      <p class="mt-4 text-slate max-w-2xl">From our Articles of Cooperation, Article III — the nine aims that guide everything we do.</p>
      <div class="mt-10 grid md:grid-cols-2 gap-5">
        {GOALS.map(g => {
          const Icon = iconOf(g.icon);
          return (
            <div class="bg-white border-t-[3px] border-navy rounded-b-lg p-5 flex gap-4">
              <div class="shrink-0 w-10 h-10 rounded-lg bg-navy/5 text-navy flex items-center justify-center"><Icon class="w-5 h-5" /></div>
              <p class="text-sm text-ink self-center">{g.text}</p>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- COOPERATIVE PRINCIPLES -->
  <section class="relative bg-navy text-white overflow-hidden">
    <GradientOrb position="bottom-left" size="md" intensity={0.15} />
    <div class="container-page py-20 relative">
      <Eyebrow color="orange">How we operate</Eyebrow>
      <h2 class="mt-3 text-3xl md:text-4xl text-white max-w-2xl">The seven cooperative principles.</h2>
      <p class="mt-4 text-white/75 max-w-2xl">The guidelines by which cooperatives the world over put their values into practice, as set out by the International Cooperative Alliance — and the standards we hold ourselves to.</p>
      <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {PRINCIPLES.map(p => {
          const Icon = iconOf(p.icon);
          return (
            <div class="bg-white/5 border border-white/15 rounded-lg p-6">
              <div class="flex items-center gap-3">
                <div class="flex items-center justify-center w-9 h-9 rounded-full bg-orange text-white font-display font-extrabold text-sm">{p.number}</div>
                <Icon class="w-6 h-6 text-orange" />
              </div>
              <div class="mt-4 font-display font-bold text-white">{p.title}</div>
              <p class="mt-2 text-sm text-white/70 leading-relaxed">{p.body}</p>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- COOPERATIVE IDENTITY MARQUE -->
  <section class="bg-brand-bg">
    <div class="container-page py-14 flex justify-center">
      <CoopMarque variant="message" message={1} color="blk" width={300} alt="Co-operative Marque: People together are stronger" />
    </div>
  </section>

  <!-- GOVERNANCE -->
  <section class="container-page py-20">
    <Eyebrow>How we're governed</Eyebrow>
    <h2 class="mt-3 text-3xl md:text-4xl">Board of Directors</h2>
    <p class="mt-4 text-slate max-w-2xl">A 9-member board elected by members through secret ballot at the Annual General Assembly. Directors serve 2-year terms. Appointed officers and management leadership round out our governance.</p>
    <div class="mt-10 grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
      {BOARD.map(m => <BodCard member={m} />)}
    </div>
  </section>

  <!-- AFFILIATIONS -->
  <section class="bg-brand-bg">
    <div class="container-page py-16">
      <Eyebrow>Where we belong</Eyebrow>
      <h2 class="mt-3 text-3xl md:text-4xl">Affiliations & credentials</h2>
      <div class="mt-10 grid md:grid-cols-3 gap-6">
        <div class="bg-white border-t-[3px] border-navy rounded-b-lg p-6">
          <div class="text-xs font-display font-bold text-orange uppercase tracking-wider mb-2">CDA</div>
          <div class="font-display font-bold text-navy">Cooperative Development Authority</div>
          <p class="mt-2 text-sm text-slate">Registration No. 9520-06008210 · Member in Good Standing</p>
        </div>
        <div class="bg-white border-t-[3px] border-navy rounded-b-lg p-6">
          <div class="text-xs font-display font-bold text-orange uppercase tracking-wider mb-2">NATCCO</div>
          <div class="font-display font-bold text-navy">National Confederation of Cooperatives</div>
          <p class="mt-2 text-sm text-slate">MIGS — Member in Good Standing</p>
        </div>
        <div class="bg-white border-t-[3px] border-navy rounded-b-lg p-6">
          <div class="text-xs font-display font-bold text-orange uppercase tracking-wider mb-2">BIR</div>
          <div class="font-display font-bold text-navy">Bureau of Internal Revenue</div>
          <p class="mt-2 text-sm text-slate">Cooperative tax-exempt status · Form 2303 registered</p>
        </div>
        <div class="bg-white border-t-[3px] border-navy rounded-b-lg p-6">
          <div class="text-xs font-display font-bold text-orange uppercase tracking-wider mb-2">WVAC</div>
          <div class="font-display font-bold text-navy">Western Visayas Alliance of Cooperatives</div>
          <p class="mt-2 text-sm text-slate">Member — regional cooperative alliance</p>
        </div>
        <div class="bg-white border-t-[3px] border-navy rounded-b-lg p-6">
          <div class="text-xs font-display font-bold text-orange uppercase tracking-wider mb-2">CLIMBS</div>
          <div class="font-display font-bold text-navy">CLIMBS Life and General Insurance Cooperative</div>
          <p class="mt-2 text-sm text-slate">Partner — cooperative insurance provider</p>
        </div>
        <div class="bg-white border-t-[3px] border-navy rounded-b-lg p-6">
          <div class="mb-2"><CoopMarque variant="marque" color="orange" width={84} alt="" /></div>
          <div class="font-display font-bold text-navy">Verified .coop Cooperative</div>
          <p class="mt-2 text-sm text-slate">Identity verified by DotCoop per the ICA Statement of Cooperative Identity</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-orange text-white">
    <div class="container-page py-16 text-center">
      <h2 class="text-3xl md:text-4xl text-white">Be part of our story.</h2>
      <div class="mt-6 flex justify-center gap-3 flex-wrap">
        <Button href="/membership" variant="outline" size="lg" showArrow className="!border-white !text-white hover:!bg-white hover:!text-orange">Apply to Join</Button>
      </div>
    </div>
  </section>
</PageLayout>
