---
import PageLayout from '~/layouts/PageLayout.astro';
import Eyebrow from '~/components/Eyebrow.astro';
import GradientOrb from '~/components/GradientOrb.astro';
import ContactMap from '~/components/ContactMap.astro';
import ContactForm from '~/components/ContactForm.astro';
import { Phone, Mail, MapPin, Clock, Facebook } from 'lucide-astro';
---
<PageLayout title="Contact" description="Visit, call, or message ISATUCMPC. Burgos St., La Paz, Iloilo City. (033) 330-2586. isatucmpc1964@gmail.com.">
  <section class="relative bg-navy text-white overflow-hidden">
    <GradientOrb position="top-right" size="md" intensity={0.22} />
    <div class="container-page py-16 md:py-20 relative">
      <Eyebrow color="orange">Contact</Eyebrow>
      <h1 class="mt-4 text-4xl md:text-5xl text-white">Visit · call · message.</h1>
      <p class="mt-4 text-lg text-white/85 max-w-2xl font-light">Our office is at Burgos St., La Paz, Iloilo City. Here's how to reach us.</p>
    </div>
  </section>

  <section class="container-page py-16 grid lg:grid-cols-[1fr_1.2fr] gap-10">
    <div>
      <ul class="space-y-5">
        <li class="flex gap-4">
          <div class="w-11 h-11 rounded-lg bg-navy/5 text-navy flex items-center justify-center shrink-0"><MapPin class="w-5 h-5" /></div>
          <div>
            <div class="text-xs font-display font-bold text-orange uppercase tracking-wider">Address</div>
            <div class="text-ink mt-1">Burgos St., La Paz<br />Iloilo City 5000, Iloilo, Philippines</div>
          </div>
        </li>
        <li class="flex gap-4">
          <div class="w-11 h-11 rounded-lg bg-navy/5 text-navy flex items-center justify-center shrink-0"><Phone class="w-5 h-5" /></div>
          <div>
            <div class="text-xs font-display font-bold text-orange uppercase tracking-wider">Phone</div>
            <div class="text-ink mt-1"><a href="tel:+63333302586" class="text-ink no-underline hover:underline">(033) 330-2586</a></div>
          </div>
        </li>
        <li class="flex gap-4">
          <div class="w-11 h-11 rounded-lg bg-navy/5 text-navy flex items-center justify-center shrink-0"><Mail class="w-5 h-5" /></div>
          <div>
            <div class="text-xs font-display font-bold text-orange uppercase tracking-wider">Email</div>
            <div class="text-ink mt-1"><a href="mailto:isatucmpc1964@gmail.com" class="text-ink no-underline hover:underline">isatucmpc1964@gmail.com</a></div>
          </div>
        </li>
        <li class="flex gap-4">
          <div class="w-11 h-11 rounded-lg bg-navy/5 text-navy flex items-center justify-center shrink-0"><Clock class="w-5 h-5" /></div>
          <div>
            <div class="text-xs font-display font-bold text-orange uppercase tracking-wider">Office hours</div>
            <div class="text-ink mt-1">Monday – Friday<br /><span class="text-slate text-sm">(exact hours to be confirmed by operator)</span></div>
          </div>
        </li>
        <li class="flex gap-4">
          <div class="w-11 h-11 rounded-lg bg-navy/5 text-navy flex items-center justify-center shrink-0"><Facebook class="w-5 h-5" /></div>
          <div>
            <div class="text-xs font-display font-bold text-orange uppercase tracking-wider">Facebook</div>
            <div class="text-ink mt-1"><a href="https://www.facebook.com/isatu.cmpc" target="_blank" rel="noopener" class="text-ink no-underline hover:underline">facebook.com/isatu.cmpc</a></div>
          </div>
        </li>
      </ul>
      <div class="mt-8 p-5 bg-brand-bg rounded-lg">
        <div class="text-xs font-display font-bold text-orange uppercase tracking-wider mb-1">Looking to join?</div>
        <p class="text-sm text-ink">See the membership page for eligibility, benefits, and how to apply.</p>
        <a href="/membership" class="mt-2 inline-block text-link font-semibold no-underline hover:underline">See /membership →</a>
      </div>
    </div>
    <ContactForm />
  </section>

  <section class="container-page pb-20">
    <ContactMap />
  </section>
</PageLayout>
