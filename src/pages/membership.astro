---
import PageLayout from '~/layouts/PageLayout.astro';
import Eyebrow from '~/components/Eyebrow.astro';
import Button from '~/components/Button.astro';
import GradientOrb from '~/components/GradientOrb.astro';
import BenefitCard from '~/components/BenefitCard.astro';
import FaqAccordion from '~/components/FaqAccordion.astro';
import MembershipForm from '~/components/MembershipForm.astro';
import { BENEFITS } from '~/data/benefits';
import { FAQ } from '~/data/faq';
import { buildFaqSchema } from '~/lib/seo';

const faqSchema = buildFaqSchema(FAQ);

const STEPS: Array<{ title: string; body: string; icon: string }> = [
  { title: 'Attend PMES', body: 'Pre-Membership Education Seminar — half-day cooperative orientation.', icon: 'graduation-cap' },
  { title: 'Submit application', body: 'Fill out the membership form at the office or via the link below.', icon: 'file-text' },
  { title: 'Pay fees', body: '₱500 membership fee + 25 paid-up shares (₱1,250) of 50 subscribed (₱2,500).', icon: 'wallet' },
  { title: 'BOD review', body: 'The Board of Directors acts on your application within 30 days.', icon: 'users' },
  { title: 'Welcome aboard', body: 'Member benefits activate. Start saving, borrowing, and growing with us.', icon: 'handshake' },
];

// Inline SVG paths so we don't pull a new icon dep. Each entry returns innards of a 24×24 viewBox.
const ICONS: Record<string, string> = {
  'graduation-cap': '<path d="M22 10v6"/><path d="M2 10l10-5 10 5-10 5-10-5z"/><path d="M6 12v5c0 1.7 4 3 6 3s6-1.3 6-3v-5"/>',
  'file-text': '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>',
  'wallet': '<path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"/><path d="M3 5v14a2 2 0 0 0 2 2h16v-5"/><path d="M18 12a2 2 0 0 0 0 4h4v-4z"/>',
  'users': '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  'handshake': '<path d="m11 17 2 2a1 1 0 1 0 3-3"/><path d="m14 14 2.5 2.5a1 1 0 1 0 3-3l-3.88-3.88a3 3 0 0 0-4.24 0l-.88.88a1 1 0 1 1-3-3l2.81-2.81a5.79 5.79 0 0 1 7.06-.87l.47.28a2 2 0 0 0 1.42.25L21 4"/><path d="m21 3 1 11h-2"/><path d="M3 3 2 14l6.5 6.5a1 1 0 1 0 3-3"/><path d="M3 4h8"/>',
};
---
<PageLayout title="Join ISATUCMPC" description="Become a member of Iloilo's longest-running multi-purpose cooperative. See who can join, the benefits, and how to apply." jsonLd={faqSchema}>
  <!-- HERO -->
  <section class="relative bg-navy text-white overflow-hidden">
    <GradientOrb position="top-right" size="lg" intensity={0.28} />
    <div class="container-page py-20 md:py-24 relative">
      <Eyebrow color="orange">Membership</Eyebrow>
      <h1 class="mt-4 text-4xl md:text-6xl text-white max-w-3xl">Join ISATUCMPC.</h1>
      <p class="mt-5 text-xl md:text-2xl text-white/90 max-w-2xl font-light">A community of Ilonggos saving together, borrowing together, and growing together — since 1964.</p>
      <div class="mt-10">
        <Button href="#apply" variant="primary" size="lg" showArrow>Start your application</Button>
      </div>
    </div>
  </section>

  <!-- WHO CAN JOIN -->
  <section class="container-page py-20">
    <Eyebrow>Who can join</Eyebrow>
    <h2 class="mt-3 text-3xl md:text-4xl max-w-2xl">Two ways to belong.</h2>
    <div class="mt-10 grid md:grid-cols-2 gap-6">
      <div class="bg-white border-t-[3px] border-navy rounded-b-lg p-7 flex flex-col">
        <div class="text-xs font-display font-bold text-orange uppercase tracking-wider mb-2">Regular member</div>
        <h3 class="text-2xl mb-3">Full voting rights</h3>
        <p class="text-slate mb-4">Open to <strong class="text-ink">regular employees of Iloilo Science and Technology University (ISAT U) and its satellite campuses</strong>, and <strong class="text-ink">regular employees of the cooperative</strong>.</p>
        <ul class="text-sm space-y-2 text-ink mb-5">
          <li>✓ Vote at the Annual General Assembly</li>
          <li>✓ Seek elected positions in the cooperative</li>
          <li>✓ Full access to all services and benefits</li>
        </ul>
        <a href="/forms/Regular_Application_Form.pdf" download class="mt-auto inline-flex items-center gap-2 text-sm font-display font-bold text-navy no-underline border-2 border-navy hover:bg-navy hover:text-white transition rounded-md px-4 py-2 self-start">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download Regular form (PDF)
        </a>
      </div>
      <div class="bg-white border-t-[3px] border-navy rounded-b-lg p-7 flex flex-col">
        <div class="text-xs font-display font-bold text-orange uppercase tracking-wider mb-2">Associate member</div>
        <h3 class="text-2xl mb-3">Full service access</h3>
        <p class="text-slate mb-4">Open to <strong class="text-ink">alumni of ISAT U</strong>, <strong class="text-ink">parents, spouses, and children (of legal age) of regular members</strong>, and <strong class="text-ink">non-regular University employees</strong>.</p>
        <ul class="text-sm space-y-2 text-ink mb-5">
          <li>✓ Access to all cooperative services</li>
          <li>✓ Earn savings and patronage refunds</li>
          <li>✓ May convert to regular after 2 years</li>
        </ul>
        <a href="/forms/Associate_Application_Form.pdf" download class="mt-auto inline-flex items-center gap-2 text-sm font-display font-bold text-navy no-underline border-2 border-navy hover:bg-navy hover:text-white transition rounded-md px-4 py-2 self-start">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download Associate form (PDF)
        </a>
      </div>
    </div>
  </section>

  <!-- BENEFITS -->
  <section class="bg-brand-bg">
    <div class="container-page py-20">
      <Eyebrow>What you get</Eyebrow>
      <h2 class="mt-3 text-3xl md:text-4xl">Member benefits</h2>
      <div class="mt-10 grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        {BENEFITS.map(b => <BenefitCard benefit={b} />)}
      </div>
    </div>
  </section>

  <!-- HOW TO APPLY -->
  <section class="container-page py-24">
    <Eyebrow>The process</Eyebrow>
    <h2 class="mt-3 text-3xl md:text-4xl">How to apply</h2>
    <p class="mt-4 text-slate max-w-2xl">Five clear steps from interested to welcomed.</p>

    <ol class="mt-16 grid grid-cols-1 lg:grid-cols-5 gap-x-4 gap-y-14">
      {STEPS.map((step, i) => (
        <li class="relative flex flex-col items-center text-center">
          <!-- Numbered icon badge -->
          <div class="relative inline-flex">
            <div class="w-24 h-24 rounded-full bg-navy ring-4 ring-gold/40 shadow-lg shadow-navy/10 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#FE9900" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={ICONS[step.icon]} />
            </div>
            <span class="absolute -top-1 -right-1 min-w-[34px] h-[26px] px-2 inline-flex items-center justify-center rounded-full bg-orange text-white font-display font-extrabold text-xs tracking-wide ring-2 ring-white">
              {String(i + 1).padStart(2, '0')}
            </span>
          </div>

          <!-- Step content -->
          <h3 class="mt-6 font-display font-extrabold text-navy text-lg">{step.title}</h3>
          <p class="mt-2 text-sm text-slate max-w-[210px]">{step.body}</p>

          <!-- Desktop connector arc (curve to next step) -->
          {i < STEPS.length - 1 && (
            <svg
              aria-hidden="true"
              class="hidden lg:block absolute top-12 left-[calc(50%+3rem)] w-[calc(100%-2rem)] h-12 text-orange/70 pointer-events-none"
              viewBox="0 0 100 24"
              preserveAspectRatio="none"
            >
              <defs>
                <linearGradient id={`stepArcGrad-${i}`} x1="0" y1="0" x2="1" y2="0">
                  <stop offset="0%" stop-color="#FE9900" />
                  <stop offset="100%" stop-color="#FFC001" />
                </linearGradient>
              </defs>
              <path d="M 2 12 Q 50 0, 95 12" stroke={`url(#stepArcGrad-${i})`} stroke-width="2" fill="none" stroke-dasharray="3 4" stroke-linecap="round" />
              <polyline points="89 8, 95 12, 89 16" stroke={`url(#stepArcGrad-${i})`} stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          )}

          <!-- Mobile/tablet connector (vertical down between rows) -->
          {i < STEPS.length - 1 && (
            <svg
              aria-hidden="true"
              class="block lg:hidden mt-4 w-6 h-10 text-orange/70"
              viewBox="0 0 24 40"
            >
              <defs>
                <linearGradient id={`stepArcGradV-${i}`} x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="#FE9900" />
                  <stop offset="100%" stop-color="#FFC001" />
                </linearGradient>
              </defs>
              <line x1="12" y1="2" x2="12" y2="32" stroke={`url(#stepArcGradV-${i})`} stroke-width="2" stroke-dasharray="3 4" stroke-linecap="round" />
              <polyline points="6 28, 12 34, 18 28" stroke={`url(#stepArcGradV-${i})`} stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          )}
        </li>
      ))}
    </ol>
  </section>

  <!-- FAQ -->
  <section class="bg-brand-bg">
    <div class="container-page py-20">
      <Eyebrow>Frequently asked</Eyebrow>
      <h2 class="mt-3 text-3xl md:text-4xl">Questions members ask first</h2>
      <div class="mt-10 max-w-3xl">
        <FaqAccordion faqs={FAQ} />
      </div>
    </div>
  </section>

  <!-- APPLY FORM -->
  <section id="apply" class="container-page py-20 grid lg:grid-cols-[1fr_1.2fr] gap-10">
    <div>
      <Eyebrow>Ready when you are</Eyebrow>
      <h2 class="mt-3 text-3xl md:text-4xl">Start your application</h2>
      <p class="mt-4 text-slate">Fill out this form to begin. We'll review your information and email you the next steps — including the PMES schedule.</p>
      <div class="mt-8 text-sm text-slate">
        <div class="font-display font-bold text-navy mb-1">Prefer to talk?</div>
        <div>📞 (033) 330-2586</div>
        <div>✉ <a href="mailto:isatucmpc1964@gmail.com" class="text-link">isatucmpc1964@gmail.com</a></div>
      </div>
    </div>
    <MembershipForm />
  </section>
</PageLayout>
