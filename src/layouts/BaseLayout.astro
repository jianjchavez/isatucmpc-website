---
import '~/styles/global.css';
import { buildOrgSchema, buildLocalBusinessSchema } from '~/lib/seo';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  noIndex?: boolean;
  jsonLd?: Record<string, unknown>;
}

const { title, description, ogImage = '/og-default.svg', noIndex = false, jsonLd } = Astro.props;
const fullTitle = title === 'ISATUCMPC' ? title : `${title} · ISATUCMPC`;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const orgSchema = buildOrgSchema();
const localBusinessSchema = buildLocalBusinessSchema();
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#010066" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <link rel="canonical" href={canonical} />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  {noIndex && <meta name="robots" content="noindex,nofollow" />}
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
  <meta name="twitter:card" content="summary_large_image" />
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  <!-- Cloudflare Web Analytics is injected automatically by Cloudflare Pages.
       Enable it once in the dashboard: Pages project → Web Analytics → Enable.
       No beacon token belongs in this repo (the old hardcoded placeholder was a
       no-op). CSP already allows static.cloudflareinsights.com. -->
  <!-- Turnstile: explicit render so local dev/preview can fall back to Cloudflare's
       test sitekey (the real widget rejects localhost with "Unable to connect").
       Production uses each widget's real data-sitekey unchanged. -->
  <script is:inline>
    window.onloadTurnstileCallback = function () {
      if (!window.turnstile) return;
      var isLocal = ['localhost', '127.0.0.1', '[::1]'].indexOf(location.hostname) !== -1;
      document.querySelectorAll('.cf-turnstile').forEach(function (el) {
        if (el.dataset.rendered) return;
        el.dataset.rendered = '1';
        window.turnstile.render(el, {
          // 1x00000000000000000000AA = CF's official "always passes" test key (localhost only)
          sitekey: isLocal ? '1x00000000000000000000AA' : el.dataset.sitekey,
        });
      });
    };
  </script>
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit&onload=onloadTurnstileCallback" async defer></script>
  <script src="/forms.js" defer></script>
</head>
<body class="font-body text-ink antialiased">
  <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:bg-navy focus:text-white focus:px-4 focus:py-2 focus:rounded">Skip to main content</a>
  <slot />
</body>
</html>
