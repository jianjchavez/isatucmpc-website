---
import Button from '~/components/Button.astro';

const CAMPUSES = ['Main La Paz', 'Dumangas', 'Barotac Nuevo', 'Leon', 'Miag-ao'];
---
<form id="membership-form" class="bg-white border-t-[3px] border-orange rounded-b-lg p-6 md:p-8 space-y-5" novalidate>
  <input type="hidden" name="form-source" value="membership" />
  <input type="hidden" name="name" value="" />
  <input type="hidden" name="message" value="" />

  <fieldset class="space-y-4">
    <legend class="font-display font-bold text-navy text-sm uppercase tracking-wider">Your details</legend>
    <div class="grid md:grid-cols-3 gap-4">
      <div>
        <label for="mf-first" class="block text-xs font-display font-bold text-navy uppercase tracking-wider mb-1">First name <span class="text-orange" aria-hidden="true">*</span></label>
        <input id="mf-first" data-field="firstName" type="text" required class="w-full border-2 border-rule focus:border-navy rounded-md px-3 py-2 text-sm" />
      </div>
      <div>
        <label for="mf-middle" class="block text-xs font-display font-bold text-navy uppercase tracking-wider mb-1">Middle name</label>
        <input id="mf-middle" data-field="middleName" type="text" class="w-full border-2 border-rule focus:border-navy rounded-md px-3 py-2 text-sm" />
      </div>
      <div>
        <label for="mf-last" class="block text-xs font-display font-bold text-navy uppercase tracking-wider mb-1">Last name <span class="text-orange" aria-hidden="true">*</span></label>
        <input id="mf-last" data-field="lastName" type="text" required class="w-full border-2 border-rule focus:border-navy rounded-md px-3 py-2 text-sm" />
      </div>
    </div>
    <div class="grid md:grid-cols-2 gap-4">
      <div>
        <label for="mf-email" class="block text-xs font-display font-bold text-navy uppercase tracking-wider mb-1">Email <span class="text-orange" aria-hidden="true">*</span></label>
        <input id="mf-email" name="email" type="email" required class="w-full border-2 border-rule focus:border-navy rounded-md px-3 py-2 text-sm" />
      </div>
      <div>
        <label for="mf-phone" class="block text-xs font-display font-bold text-navy uppercase tracking-wider mb-1">Contact number <span class="text-orange" aria-hidden="true">*</span></label>
        <input id="mf-phone" data-field="phone" type="tel" required inputmode="tel" placeholder="09xx xxx xxxx" class="w-full border-2 border-rule focus:border-navy rounded-md px-3 py-2 text-sm" />
      </div>
    </div>
    <div class="grid md:grid-cols-2 gap-4">
      <div>
        <label for="mf-dob" class="block text-xs font-display font-bold text-navy uppercase tracking-wider mb-1">Date of birth <span class="text-orange" aria-hidden="true">*</span></label>
        <input id="mf-dob" data-field="dob" type="date" required class="w-full border-2 border-rule focus:border-navy rounded-md px-3 py-2 text-sm" />
      </div>
    </div>
  </fieldset>

  <fieldset class="space-y-3">
    <legend class="font-display font-bold text-navy text-sm uppercase tracking-wider">Membership type</legend>
    <div class="flex flex-wrap gap-4">
      <label class="flex items-center gap-2 text-sm"><input type="radio" data-field="memberType" name="mf-membertype" value="Regular" required /> Regular member</label>
      <label class="flex items-center gap-2 text-sm"><input type="radio" data-field="memberType" name="mf-membertype" value="Associate" /> Associate member</label>
    </div>

    <div id="mf-associate-block" class="hidden border-l-2 border-orange/40 pl-4">
      <label for="mf-recommender" class="block text-xs font-display font-bold text-navy uppercase tracking-wider mb-1">Recommended by (regular member's name) <span class="text-orange" aria-hidden="true">*</span></label>
      <input id="mf-recommender" data-field="recommender" type="text" placeholder="Full name of the regular member endorsing you" class="w-full border-2 border-rule focus:border-navy rounded-md px-3 py-2 text-sm" />
      <p class="mt-1 text-xs text-slate">Associate applications require a recommending regular member.</p>
    </div>

    <div id="mf-regular-block" class="hidden border-l-2 border-orange/40 pl-4 space-y-3">
      <label class="flex items-center gap-2 text-sm">
        <input id="mf-isatu" data-field="isatuEmployee" type="checkbox" />
        I'm a regular ISAT U employee
      </label>
      <div id="mf-campus-row" class="hidden">
        <label for="mf-campus" class="block text-xs font-display font-bold text-navy uppercase tracking-wider mb-1">Campus assigned</label>
        <select id="mf-campus" data-field="campus" class="w-full border-2 border-rule focus:border-navy rounded-md px-3 py-2 text-sm bg-white">
          <option value="">Select campus…</option>
          {CAMPUSES.map(c => <option value={c}>{c}</option>)}
        </select>
      </div>
    </div>
  </fieldset>

  <fieldset class="space-y-4">
    <legend class="font-display font-bold text-navy text-sm uppercase tracking-wider">A bit more</legend>
    <div>
      <label for="mf-affiliation" class="block text-xs font-display font-bold text-navy uppercase tracking-wider mb-1">Your connection to ISAT U or our community</label>
      <input id="mf-affiliation" data-field="affiliation" type="text" placeholder="e.g. Faculty since 2018, alumna 2010, child of member …" class="w-full border-2 border-rule focus:border-navy rounded-md px-3 py-2 text-sm" />
    </div>
    <div>
      <label for="mf-notes" class="block text-xs font-display font-bold text-navy uppercase tracking-wider mb-1">Anything to add? <span class="text-slate font-normal normal-case tracking-normal">(optional)</span></label>
      <textarea id="mf-notes" data-field="notes" rows="3" class="w-full border-2 border-rule focus:border-navy rounded-md px-3 py-2 text-sm"></textarea>
    </div>
  </fieldset>

  <div class="cf-turnstile" data-sitekey="REPLACE_BEFORE_DEPLOY"></div>
  <div class="text-xs text-slate">By submitting, you agree to be contacted about next steps. We'll email you the PMES schedule and the full application form (PDF) for in-person signing at the cooperative office.</div>
  <Button type="submit" variant="primary" size="md" showArrow>Submit application</Button>
  <div id="mf-result" class="hidden p-3 rounded text-sm" role="status" aria-live="polite"></div>
</form>

<script is:inline>
  (() => {
    const form = document.getElementById('membership-form');
    if (!form) return;

    const associate = document.getElementById('mf-associate-block');
    const regular = document.getElementById('mf-regular-block');
    const isatuChk = document.getElementById('mf-isatu');
    const campusRow = document.getElementById('mf-campus-row');
    const recommender = document.getElementById('mf-recommender');

    function syncType() {
      const t = form.querySelector('input[name="mf-membertype"]:checked')?.value;
      const isAssoc = t === 'Associate';
      const isReg = t === 'Regular';
      associate.classList.toggle('hidden', !isAssoc);
      regular.classList.toggle('hidden', !isReg);
      recommender.required = isAssoc;
      if (!isReg) {
        isatuChk.checked = false;
        campusRow.classList.add('hidden');
      }
    }
    form.querySelectorAll('input[name="mf-membertype"]').forEach(el => el.addEventListener('change', syncType));
    isatuChk.addEventListener('change', () => campusRow.classList.toggle('hidden', !isatuChk.checked));

    // Pack data-field values into the worker's expected `name` + `message`
    // shape just before forms.js's bubble-phase submit handler reads FormData.
    form.addEventListener('submit', () => {
      const val = (sel) => form.querySelector(sel)?.value?.trim() || '';
      const first = val('[data-field="firstName"]');
      const middle = val('[data-field="middleName"]');
      const last = val('[data-field="lastName"]');
      form.elements['name'].value = [first, middle, last].filter(Boolean).join(' ');

      const t = form.querySelector('input[name="mf-membertype"]:checked')?.value || '';
      const isReg = t === 'Regular';
      const isAssoc = t === 'Associate';
      const isatu = isReg && isatuChk.checked;
      const rows = [
        ['Contact number', val('[data-field="phone"]')],
        ['Date of birth', val('[data-field="dob"]')],
        ['Membership type', t],
        ['Recommending regular member', isAssoc ? val('[data-field="recommender"]') : ''],
        ['ISAT U employee', isReg ? (isatu ? 'Yes' : 'No') : ''],
        ['Campus', isatu ? val('[data-field="campus"]') : ''],
        ['Connection to ISAT U / community', val('[data-field="affiliation"]')],
        ['Notes', val('[data-field="notes"]')],
      ].filter(([, v]) => v);
      form.elements['message'].value = rows.length
        ? rows.map(([k, v]) => `${k}: ${v}`).join('\n')
        : '(no additional details)';
    }, true);  // capture phase: runs before forms.js bubble handler
  })();
</script>
