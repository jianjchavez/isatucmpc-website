    <div class="mt-12 pt-6 border-t border-white/15 flex flex-col md:flex-row justify-between gap-3 text-[11px] opacity-60">
      <span>© {year} ISATUCMPC · Service-driven since 1964</span>
      <span><a href="https://www.facebook.com/isatu.cmpc" target="_blank" rel="noopener noreferrer" class="text-white no-underline hover:underline">facebook.com/isatu.cmpc</a></span>
    </div>
  </div>
</footer>
