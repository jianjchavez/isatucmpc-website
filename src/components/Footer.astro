            <li><a href="/contact" class="text-white no-underline hover:underline">Contact</a></li>
          </ul>
        </nav>
      </div>

      <div>
        <div class="font-display font-bold text-xs uppercase tracking-widest text-orange mb-3">Members</div>
        <nav aria-label="Members">
          <ul class="text-xs space-y-2 opacity-90">
            <li><a href="https://app.isatucmpc.coop" target="_blank" rel="noopener noreferrer" class="text-white no-underline hover:underline">Member Login</a></li>
            <li><a href="/membership" class="text-white no-underline hover:underline">Apply to Join</a></li>
            <li><a href="/news?category=announcement" class="text-white no-underline hover:underline">Announcements</a></li>
          </ul>
        </nav>
      </div>

      <div>
        <div class="font-display font-bold text-xs uppercase tracking-widest text-orange mb-3">Official</div>
        <p class="text-xs opacity-90 leading-relaxed">
