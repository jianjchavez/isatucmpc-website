---
const year = new Date().getFullYear();
---
<footer class="bg-navy text-white">
  <div class="container-page py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <div>
        <div class="flex items-center gap-3 mb-3">
          <img src="/logo.svg" alt="" class="h-10 w-10" />
          <div class="font-display font-extrabold text-sm">ISATUCMPC</div>
        </div>
        <p class="text-xs leading-relaxed opacity-75">
          Iloilo Science and Technology University<br />and Community Multi-Purpose Cooperative<br /><br />
          Magdalo St., La Paz, Iloilo City<br />
          (033) 330-2586<br />
          <a href="mailto:isatucmpc1964@gmail.com" class="text-white no-underline hover:underline underline-offset-2">isatucmpc1964@gmail.com</a>
        </p>
      </div>

      <div>
        <div class="font-display font-bold text-xs uppercase tracking-widest text-orange mb-3">Explore</div>
        <nav aria-label="Explore">
          <ul class="text-xs space-y-2 opacity-90">
            <li><a href="/about" class="text-white no-underline hover:underline">About</a></li>
            <li><a href="/services" class="text-white no-underline hover:underline">Services</a></li>
            <li><a href="/membership" class="text-white no-underline hover:underline">Membership</a></li>
