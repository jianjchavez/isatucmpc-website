---
import type { Service } from '~/data/services';
import * as icons from 'lucide-astro';

interface Props { service: Service; compact?: boolean; }
const { service, compact = false } = Astro.props;
const Icon = (icons as Record<string, any>)[toPascal(service.icon)] ?? icons.Circle;
function toPascal(s: string) {
  return s.split('-').map(p => p[0].toUpperCase() + p.slice(1)).join('');
}
const statusLabel = { 'active': 'Active', 'coming-soon': 'Coming soon', 'by-appointment': 'By appointment' }[service.status];
const statusColor = { 'active': 'bg-success/10 text-success', 'coming-soon': 'bg-slate/10 text-slate', 'by-appointment': 'bg-navy/10 text-navy' }[service.status];
---
<article class="border-t-[3px] border-navy bg-white rounded-b-lg p-6 shadow-sm hover:shadow-md transition" id={service.slug}>
  <div class="flex items-start justify-between gap-4 mb-3">
    <div class="w-10 h-10 rounded-lg bg-navy/5 text-navy flex items-center justify-center">
      <Icon class="w-5 h-5" />
    </div>
    <span class={`text-[10px] font-display font-bold uppercase tracking-wider px-2 py-1 rounded ${statusColor}`}>{statusLabel}</span>
  </div>
  <h3 class="text-lg mb-2">{service.name}</h3>
  <p class="text-sm text-slate mb-4">{service.description}</p>
  {!compact && (
    <>
      <div class="text-xs font-display font-bold uppercase tracking-wider text-orange mt-4 mb-2">Who can use this</div>
      <p class="text-sm text-ink mb-4">{service.whoCanUse}</p>
      <div class="text-xs font-display font-bold uppercase tracking-wider text-orange mt-4 mb-2">How to access</div>
      <ol class="text-sm text-ink list-decimal list-inside space-y-1">
        {service.howToAccess.map(step => <li>{step}</li>)}
      </ol>
    </>
  )}
</article>
