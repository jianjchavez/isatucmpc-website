<div id="contact-map" class="w-full h-[400px] rounded-lg border-2 border-rule" aria-label="Map showing ISATUCMPC office at Burgos St., La Paz, Iloilo City"></div>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
<script>
  import L from 'leaflet';
  // Burgos St., La Paz, Iloilo City — operator-confirmed coordinates (2026-05-30)
  const lat = 10.71723505138329;
  const lng = 122.56531801867675;
  const map = L.map('contact-map', { scrollWheelZoom: false }).setView([lat, lng], 17);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    maxZoom: 19,
    attribution: '© OpenStreetMap contributors',
  }).addTo(map);
  L.marker([lat, lng]).addTo(map).bindPopup(`ISATUCMPC<br>Burgos St., La Paz, Iloilo City<br><a href="https://www.google.com/maps/search/?api=1&query=${lat},${lng}" target="_blank" rel="noopener">Open in Google Maps</a>`).openPopup();
</script>
