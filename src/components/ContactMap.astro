<div id="contact-map" class="w-full h-[400px] rounded-lg border-2 border-rule" aria-label="Map showing ISATUCMPC office at Magdalo St., La Paz, Iloilo City"></div>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
<script>
  import L from 'leaflet';
  // Magdalo St., La Paz, Iloilo City (Plus Code PH88+P47)
  const lat = 10.716854621163616;
  const lng = 122.56531309729111;
  const map = L.map('contact-map', { scrollWheelZoom: false }).setView([lat, lng], 16);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    maxZoom: 19,
    attribution: '© OpenStreetMap contributors',
  }).addTo(map);
  L.marker([lat, lng]).addTo(map).bindPopup('ISATUCMPC<br>Magdalo St., La Paz, Iloilo City<br><a href="https://www.google.com/maps/search/?api=1&query=PH88%2BP47+Iloilo+City" target="_blank" rel="noopener">Open in Google Maps (Plus Code PH88+P47)</a>').openPopup();
</script>
