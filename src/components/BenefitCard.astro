---
import type { Benefit } from '~/data/benefits';
import * as icons from 'lucide-astro';
interface Props { benefit: Benefit; }
const { benefit } = Astro.props;
function toPascal(s: string) { return s.split('-').map(p => p[0].toUpperCase() + p.slice(1)).join(''); }
const Icon = (icons as Record<string, any>)[toPascal(benefit.icon)] ?? icons.CheckCircle;
---
<article class="border-t-[3px] border-navy bg-white rounded-b-lg p-6">
  <div class="w-12 h-12 rounded-lg bg-orange/10 text-orange flex items-center justify-center mb-4">
    <Icon class="w-6 h-6" />
  </div>
  <h3 class="text-base mb-2">{benefit.title}</h3>
  <p class="text-sm text-slate">{benefit.body}</p>
</article>
