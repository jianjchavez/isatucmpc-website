---
import { TIMELINE } from '~/data/timeline';
---
<ol class="relative border-l-2 border-orange/30 ml-3 md:ml-8 space-y-10">
  {TIMELINE.map(entry => (
    <li class="ml-6 md:ml-8">
      <span class="absolute -left-[9px] flex items-center justify-center w-4 h-4 rounded-full bg-orange ring-4 ring-white"></span>
      <div class="font-display font-extrabold text-navy text-2xl md:text-3xl">{entry.year}</div>
      <div class="font-display font-semibold text-orange text-[11px] uppercase tracking-widest mt-1 mb-2">{entry.title}</div>
      <p class="text-sm md:text-base text-ink max-w-2xl">{entry.body}</p>
    </li>
  ))}
</ol>
