---
import type { FaqItem } from '~/data/faq';
interface Props { faqs: FaqItem[]; }
const { faqs } = Astro.props;
---
<div class="space-y-3">
  {faqs.map(f => (
    <details class="bg-white border-t-[3px] border-navy rounded-b-lg p-5 group">
      <summary class="cursor-pointer font-display font-semibold text-navy flex items-center justify-between list-none">
        <span>{f.q}</span>
        <span class="text-orange text-2xl leading-none group-open:rotate-45 transition-transform">+</span>
      </summary>
      <p class="mt-3 text-sm text-ink leading-relaxed">{f.a}</p>
    </details>
  ))}
</div>
